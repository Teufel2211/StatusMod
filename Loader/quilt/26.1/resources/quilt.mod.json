{
  "schema_version": 1,
  "quilt_loader": {
    "id": "${modid}",
    "version": "${version}",
    "metadata": {
      "name": "${name}",
      "description": "Configurable player status tags for TAB and name rendering with /status, /settings, and admin controls.",
      "license": "MIT",
      "icon": "assets/status-mod/icon.png",
      "contact": {
        "homepage": "https://github.com/Teufel2211/StatusMod",
        "issues": "https://github.com/Teufel2211/StatusMod/issues",
        "sources": "https://github.com/Teufel2211/StatusMod"
      }
    },
    "entrypoints": {
      "main": ["com.teufel.statusmod.StatusMod"]
    }
  },
  "depends": [
    {
      "id": "minecraft",
      "versions": ["${minecraft_version}"]
    },
    {
      "id": "quilted_fabric_api",
      "versions": ["*"]
    }
  ]
}
